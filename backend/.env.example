# Gemma provider:
#   "vertex" → Vertex AI Model Garden MaaS (recommended, default)
#   "google" → Google AI Studio (fallback)
#   "ollama" → local Ollama (offline / on-device toggle)
GEMMA_PROVIDER=vertex

# ---------- Vertex AI Model Garden (primary) ----------
# Auth uses Application Default Credentials — no API key.
# Local dev:
#   gcloud auth application-default login
# Cloud Run: attach a service account with roles/aiplatform.user.
GCP_PROJECT_ID=your-gcp-project-id
# For Gemma 4 MaaS use "global" (not a regional endpoint).
GCP_REGION=global
VERTEX_MODEL_ID=gemma-4-26b-a4b-it-maas

# ---------- Google AI Studio (fallback) ----------
# Only used when GEMMA_PROVIDER=google. Get a key at
# https://aistudio.google.com/apikey
GEMMA_API_KEY=
GEMMA_MODEL=gemma-4-26b-a4b-it

# ---------- Ollama (offline fallback) ----------
# Only used when GEMMA_PROVIDER=ollama. 26B needs ~16GB VRAM; on smaller
# machines set OLLAMA_MODEL=gemma4:e4b.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:26b

# App settings
APP_ENV=development
DATABASE_URL=sqlite:///./gemmaplay.db
STORAGE_BACKEND=local      # local | gcs
GCS_BUCKET=                # filled in when deploying to GCP
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Logging
LOG_LEVEL=INFO
